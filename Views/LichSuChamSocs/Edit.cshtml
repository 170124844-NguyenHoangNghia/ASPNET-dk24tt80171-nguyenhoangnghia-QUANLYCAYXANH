@model QUANLYCAYXANH.Models.LichSuChamSoc

<h2>Sửa lịch chăm sóc</h2>

<form asp-action="Edit">

    <input type="hidden" asp-for="MaChamSoc" />

    <div class="mb-3">
        <label>Cây xanh</label>

        <select asp-for="MaCay"
                asp-items="ViewBag.MaCay"
                class="form-control">
        </select>
    </div>

    <div class="mb-3">
        <label>Loại chăm sóc</label>

        <input asp-for="LoaiChamSoc"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Ngày chăm sóc</label>

        <input asp-for="NgayChamSoc"
               type="date"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Ghi chú</label>

        <textarea asp-for="GhiChu"
                  class="form-control">
        </textarea>
    </div>

    <button type="submit"
            class="btn btn-warning">
        Cập nhật
    </button>

</form>