@model QUANLYCAYXANH.Models.KhuVuc

<h2>Thêm khu vực</h2>

<form asp-action="Create">

    <div class="mb-3">
        <label class="form-label">Tên khu vực</label>
        <input asp-for="TenKhuVuc" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Mô tả</label>
        <input asp-for="MoTa" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">
        Lưu
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Quay lại
    </a>

</form>