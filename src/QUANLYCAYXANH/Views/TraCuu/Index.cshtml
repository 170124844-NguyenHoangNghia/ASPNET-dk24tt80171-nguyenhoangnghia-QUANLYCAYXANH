@model IEnumerable<QUANLYCAYXANH.Models.CayXanh>
<div class="d-flex justify-content-between align-items-center mb-3">

    <h2>Tra cứu cây xanh</h2>

</div>

<form method="get" class="mb-3">

    <div class="input-group">

        <input type="text"
               name="searchString"
               class="form-control"
               placeholder="Nhập tên cây..." />

        <button class="btn btn-success">
            Tìm kiếm
        </button>

    </div>

</form>
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">

        @TempData["Success"]

    </div>
}

<table class="table table-bordered">

    <thead>

        <tr>
            <th>Tên cây</th>
            <th>Loài cây</th>
            <th>Khu vực</th>
            <th>Tình trạng</th>
            <th></th>
        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.TenCay</td>

                <td>@item.LoaiCay</td>

                <td>@item.KhuVuc?.TenKhuVuc</td>

                <td>@item.TinhTrang</td>

                <td>

                    <a asp-controller="BaoCaoSuCos"
                       asp-action="Create"
                       asp-route-id="@item.MaCay"
                       class="btn btn-danger btn-sm">

                        Báo cáo sự cố

                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>