@model QUANLYCAYXANH.Models.ViewModels.LoginVM

@{
    Layout = null;
}

<!DOCTYPE html>

<html>

<head>

    <meta name="viewport" content="width=device-width" />

    <title>Đăng nhập hệ thống</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

</head>

<body class="bg-light">

    <div class="container">

        <div class="row justify-content-center mt-5">

            <div class="col-md-5">

                <div class="card shadow">

                    <div class="card-header bg-success text-white text-center">

                        <h3>
                            HỆ THỐNG QUẢN LÝ CÂY XANH
                        </h3>

                    </div>

                    <div class="card-body">

                        <form method="post">

                            <div class="mb-3">

                                <label class="form-label">
                                    Tên đăng nhập
                                </label>

                                <input asp-for="TenDangNhap"
                                       class="form-control" />

                            </div>

                            <div class="mb-3">

                                <label class="form-label">
                                    Mật khẩu
                                </label>

                                <input asp-for="MatKhau"
                                       type="password"
                                       class="form-control" />

                            </div>

                            @if (ViewBag.Error != null)
                            {
                                <div class="alert alert-danger">

                                    @ViewBag.Error

                                </div>
                            }

                            <button type="submit"
                                    class="btn btn-success w-100">

                                Đăng nhập

                            </button>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>

</body>

</html>